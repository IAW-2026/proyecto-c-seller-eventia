generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model eventos {
  idEvento      Int     @id @default(autoincrement())
  nombreEvento  String?
  descripcion   String?
  fecha         DateTime?
  ubicacion     String?
  stock         Int?
  idOrganizador String?
  precio        Float?  @db.Real

  organizador   organizadores? @relation(fields: [idOrganizador], references: [idOrganizador])
  pedidos       pedidos[]
}

model organizadores {
  idOrganizador     String  @id            // usar el ID que entrega Clerk (ej. user.id)
  nombreOrganizador String?
  apellido          String?
  mail              String?
  eventos           eventos[]
  pedidos           pedidos[]
}

model pedidos {
  idPedido      Int     @id @default(autoincrement())
  idOrganizador String?
  idUsuario     Int?
  idEvento      Int?
  idTransaccion Int?
  cantEntradas  Int?
  monto         Float?  @db.Real

  organizador   organizadores? @relation(fields: [idOrganizador], references: [idOrganizador])
  evento        eventos?       @relation(fields: [idEvento], references: [idEvento])
}